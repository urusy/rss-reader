# ---- Database (ローカル開発: just dev-db の Postgres に接続) ----
# compose 起動には POSTGRES_PASSWORD が必須（既定値なし・未設定なら起動失敗）。
# DATABASE_URL のパスワード部分も合わせて変更すること。
POSTGRES_PASSWORD=rss
DATABASE_URL=postgres://rss:rss@localhost:5432/rssreader

# ---- Server ----
BIND_ADDR=0.0.0.0:8080

# ---- Claude (要約・翻訳。未設定でもRSSリーダーは動作。該当機能のみ503) ----
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Auth (パスワードログイン) ----
# 初回アクセス時に画面からパスワードを設定する（環境変数は不要）。
# セッションは HttpOnly Cookie。HTTPS 終端がある構成でだけ Secure 属性を
# 付ける（http のみの LAN で true にすると Cookie が保存されずログイン不能）。
# COOKIE_SECURE=true
# パスワードを忘れたら DB で `DELETE FROM auth_credential;` を実行すると
# セットアップ画面が再表示される（README のセキュリティ節を参照）。

# ---- Feed scheduler ----
FEED_REFRESH_INTERVAL_SECS=900

# ---- SSRF guard (フィード/全文抽出/フィード発見の取得先制限) ----
# 既定はプライベート/ループバックアドレスへの取得を拒否（クラウドメタデータや
# 内部サービスへの SSRF 防御）。LAN 内のフィード（NAS 上のサービス等)を
# 購読したい場合のみ true にする。
# ALLOW_PRIVATE_NETWORKS=true

# ---- CORS ----
# 既定はクロスオリジン不許可（nginx / Vite proxy 経由なら同一オリジンなので不要）。
# 別オリジンのフロントから /api を直接叩く構成のときだけ、カンマ区切りで指定。
# CORS_ALLOWED_ORIGINS=https://reader.example.com

# ---- Backup / restore (機能15) ----
# /api/backup/* を有効化するトークン（未設定なら 503）。export/import は機微なので必須。
# BACKUP_TOKEN=
# 任意の定期 pg_dump（両方設定したときだけ起動。pg_dump がコンテナに必要）。
# BACKUP_DIR=/backups
# BACKUP_PGDUMP_INTERVAL_SECS=86400

# ---- Full-content extraction (機能13: 記事本文をオンデマンド抽出) ----
# クロール時に自動で全文抽出するか（既定 false=オンデマンドのみ）。
# true にすると新着記事ごとに元サイトへ GET が飛ぶので相手サイトへの配慮が必要。
EXTRACT_ON_CRAWL=false
# 抽出のために取得するページの最大バイト数（巨大ページの防御）。
EXTRACT_MAX_BYTES=3000000
# 「意味のある本文」とみなす最小プレーンテキスト文字数。これ未満は抽出失敗扱い。
EXTRACT_MIN_CHARS=200

# ---- Web Push 通知 (機能31) ----
# 優先度「高」のフィードの新着をブラウザ/PWA へ Web Push で通知する。
# 両方セットで有効化（片方でも欠ければ /api/push/* は 503）。鍵は必ず自分で生成し、
# コミットしないこと。生成: scripts/gen-vapid.sh（openssl 必須）。
#   VAPID_PUBLIC_KEY  = base64url の非圧縮公開点（SW の applicationServerKey）
#   VAPID_PRIVATE_KEY = base64url の P-256 秘密鍵スカラー（VAPID JWT 署名用）
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ---- 利用状況の記録・可視化 ----
# 利用イベント（usage_events / llm_usage_events）の保持日数。日次パージで期限切れを削除。
# 0 で無期限保持（パージ無効）。既定 365。
# USAGE_RETENTION_DAYS=365

# ---- 同期（Google Reader 互換 API・機能29） ----
# NetNewsWire / Reeder 等のクライアントから同期バックエンドとして使えるようにする。
# 無認証の到達面（/accounts/ClientLogin・/reader/api/0/*）を持つため既定 off。
# 公開時は Cloudflare Access 等の前置を推奨（README「同期」参照）。
# SYNC_API_ENABLED=true
