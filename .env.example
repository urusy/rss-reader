# ---- Database (ローカル開発: just dev-db の Postgres に接続) ----
# docker-compose の既定認証 (rss/rss/rss) に合わせています。
DATABASE_URL=postgres://rss:rss@localhost:5432/rssreader

# ---- Server ----
BIND_ADDR=0.0.0.0:8080

# ---- Claude (要約・翻訳。未設定でもRSSリーダーは動作。該当機能のみ503) ----
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Auth (アクセス制御。未設定なら認証無効=LANそのまま) ----
# 設定すると /api 全体が Authorization: Bearer <token> 必須になる
# (health と /api/auth/* は除外)。十分長い乱数を使うこと:
#   openssl rand -base64 32
# AUTH_TOKEN=

# ---- Feed scheduler ----
FEED_REFRESH_INTERVAL_SECS=900

# ---- Backup / restore (機能15) ----
# /api/backup/* を有効化するトークン（未設定なら 503）。export/import は機微なので必須。
# BACKUP_TOKEN=
# 任意の定期 pg_dump（両方設定したときだけ起動。pg_dump がコンテナに必要）。
# BACKUP_DIR=/backups
# BACKUP_PGDUMP_INTERVAL_SECS=86400

# ---- Full-content extraction (機能13: 記事本文をオンデマンド抽出) ----
# クロール時に自動で全文抽出するか（既定 false=オンデマンドのみ）。
# true にすると新着記事ごとに元サイトへ GET が飛ぶので相手サイトへの配慮が必要。
EXTRACT_ON_CRAWL=false
# 抽出のために取得するページの最大バイト数（巨大ページの防御）。
EXTRACT_MAX_BYTES=3000000
# 「意味のある本文」とみなす最小プレーンテキスト文字数。これ未満は抽出失敗扱い。
EXTRACT_MIN_CHARS=200
